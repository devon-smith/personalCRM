# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/personal-crm

# NextAuth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3003
AUTH_SECRET=your-auth-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret

# Anthropic (AI features)
ANTHROPIC_API_KEY=your-anthropic-key

# User Profile (customize per deployment)
CRM_USER_FIRST_NAME=Devon
CRM_USER_FULL_NAME=Devon Smith
CRM_USER_BIO=a Stanford MS CS student
CRM_USER_EMAIL_SIGNOFF=Best, Devon
CRM_USER_STYLE=casual but thoughtful, uses first names, doesn't use formal openers
