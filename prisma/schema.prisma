generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  contacts             Contact[]
  jobApplications      JobApplication[]
  interactions         Interaction[]
  relationshipInsights RelationshipInsight[]
  weeklyDigests        WeeklyDigest[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core CRM Models ────────────────────────────────────────

enum ContactTier {
  INNER_CIRCLE
  PROFESSIONAL
  ACQUAINTANCE
}

model Contact {
  id              String      @id @default(uuid())
  userId          String
  name            String
  email           String?
  phone           String?
  company         String?
  role            String?
  tier            ContactTier @default(PROFESSIONAL)
  tags            String[]
  linkedinUrl     String?
  city            String?
  state           String?
  country         String?
  latitude        Float?
  longitude       Float?
  notes           String?     @db.Text
  followUpDays    Int?
  lastInteraction DateTime?
  avatarUrl       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  interactions       Interaction[]
  jobApplications    JobApplication[]    @relation("ContactJobApplications")
  relationshipInsight RelationshipInsight?

  @@index([userId])
  @@index([email])
}

enum JobStatus {
  INTERESTED
  APPLIED
  SCREEN
  ONSITE
  OFFER
  REJECTED
  CLOSED
}

model JobApplication {
  id          String    @id @default(uuid())
  userId      String
  company     String
  roleTitle   String
  url         String?
  status      JobStatus @default(INTERESTED)
  salaryRange String?
  deadline    DateTime?
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts Contact[] @relation("ContactJobApplications")

  @@index([userId])
  @@index([status])
}

enum InteractionType {
  EMAIL
  MESSAGE
  MEETING
  CALL
  NOTE
}

enum InteractionDirection {
  INBOUND
  OUTBOUND
}

model Interaction {
  id         String               @id @default(uuid())
  contactId  String
  userId     String
  type       InteractionType
  direction  InteractionDirection
  channel    String?
  subject    String?
  summary    String?              @db.Text
  occurredAt DateTime
  sourceId   String?
  createdAt  DateTime             @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([occurredAt])
}

// ─── AI Insights Models ────────────────────────────────────

model RelationshipInsight {
  id          String   @id @default(uuid())
  contactId   String   @unique
  userId      String
  healthScore Int      // 0-100
  healthLabel String   // thriving | stable | fading | dormant
  summary     String   @db.Text
  actions     String[] // recommended actions
  computedAt  DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WeeklyDigest {
  id        String   @id @default(uuid())
  userId    String
  content   String   @db.Text // JSON blob of structured digest
  weekStart DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, weekStart])
}
