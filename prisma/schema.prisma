generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ────────────────────────────────────────

model User {
  id                    String    @id @default(uuid())
  name                  String?
  email                 String?   @unique
  emailVerified         DateTime?
  image                 String?
  onboardingCompletedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  contacts             Contact[]
  interactions         Interaction[]
  relationshipInsights RelationshipInsight[]
  weeklyDigests        WeeklyDigest[]
  circles              Circle[]
  actionItems          ActionItem[]
  sightings            ContactSighting[]
  gmailSync            GmailSyncState?
  whatsappSync         WhatsAppSyncState?
  imessageSyncStates   IMessageSyncState[]
  emailMessages        EmailMessage[]
  drafts               Draft[]
  extensionTokens      ExtensionToken[]
  inboxItems           InboxItem[]
  threads              Thread[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core CRM Models ────────────────────────────────────────

enum ContactTier {
  INNER_CIRCLE
  PROFESSIONAL
  ACQUAINTANCE
}

enum ContactSource {
  MANUAL
  CSV_IMPORT
  GOOGLE_CONTACTS
  GMAIL_DISCOVER
  APPLE_CONTACTS
  IMESSAGE
  LINKEDIN
  WHATSAPP
}

enum SightingResolution {
  PENDING
  AUTO_MERGED
  REVIEW_NEEDED
  MANUALLY_MERGED
  MANUALLY_REJECTED
  NEW_CONTACT
}

model Contact {
  id              String      @id @default(uuid())
  userId          String
  name            String
  email            String?
  additionalEmails  String[]  @default([])
  phone             String?
  additionalPhones  String[]  @default([])
  company           String?
  role              String?
  tier              ContactTier @default(PROFESSIONAL)
  tags              String[]
  nicknames         String[]  @default([])
  aliases           String[]  @default([])
  linkedinUrl     String?
  city            String?
  state           String?
  country         String?
  latitude        Float?
  longitude       Float?
  notes           String?     @db.Text
  followUpDays    Int?
  lastInteraction DateTime?
  avatarUrl       String?
  birthday        DateTime?   @db.Date
  howWeMet        String?     @db.Text
  source          ContactSource @default(MANUAL)
  importedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  interactions       Interaction[]
  relationshipInsight RelationshipInsight?
  circles            ContactCircle[]
  actionItems        ActionItem[]
  sightings          ContactSighting[]
  journalEntries     JournalEntry[]
  changelog          ContactChangelog[]
  emailMessages      EmailMessage[]
  drafts             Draft[]

  inboxItems         InboxItem[]

  @@index([userId])
  @@index([email])
  @@index([userId, lastInteraction])
}

enum InteractionType {
  EMAIL
  MESSAGE
  MEETING
  CALL
  NOTE
}

enum InteractionDirection {
  INBOUND
  OUTBOUND
}

model Interaction {
  id         String               @id @default(uuid())
  contactId  String
  userId     String
  type       InteractionType
  direction  InteractionDirection
  channel    String?
  subject    String?
  summary    String?              @db.Text
  occurredAt DateTime
  sourceId    String?
  dismissedAt DateTime?
  createdAt   DateTime             @default(now())

  // Stable conversation identifier (legacy — migrating to Thread model)
  chatId      String?
  isGroupChat Boolean              @default(false)
  chatName    String?

  // Thread FK (canonical conversation identity, replaces chatId)
  threadId    String?
  thread      Thread?              @relation(fields: [threadId], references: [id])

  // Layer 3: AI classification (null = unclassified, fail-open)
  needsReply           Boolean?
  needsReplyReason     String?    // "question", "request", "emotional", "open_thread", "acknowledged", "winding_down", "fyi", "not_addressed"
  needsReplyConfidence Float?     // 0.0 - 1.0
  classifiedAt         DateTime?

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceId])
  @@index([contactId])
  @@index([occurredAt])
  @@index([userId, occurredAt])
  @@index([userId, contactId, occurredAt])
  @@index([userId, chatId, occurredAt])
  @@index([threadId])
}

// ─── Threads (canonical conversation identity) ─────────────
// A Thread is a stable, source-agnostic conversation that
// multiple Interaction records belong to. It replaces the ad-hoc
// chatId string and normalizes across source-specific threading
// (iMessage chat ROWIDs, Gmail threadIds, LinkedIn DMs, etc.)

model Thread {
  id              String    @id @default(cuid())
  userId          String
  source          String    // "imessage", "gmail", "linkedin", "whatsapp", "calendar"
  sourceThreadId  String    // original ID from source (e.g., chat ROWID, Gmail threadId)
  isGroup         Boolean   @default(false)
  displayName     String?   // computed: group name or primary contact name
  lastActivityAt  DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  participants    ThreadParticipant[]
  interactions    Interaction[]

  @@unique([userId, source, sourceThreadId])
  @@index([userId, lastActivityAt])
  @@index([userId, source])
}

model ThreadParticipant {
  id        String @id @default(cuid())
  threadId  String
  contactId String

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, contactId])
  @@index([contactId])
}

// ─── AI Insights Models ────────────────────────────────────

model RelationshipInsight {
  id          String   @id @default(uuid())
  contactId   String   @unique
  userId      String
  healthScore Int      // 0-100
  healthLabel String   // thriving | stable | fading | dormant
  summary     String   @db.Text
  actions     String[] // recommended actions
  computedAt  DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WeeklyDigest {
  id        String   @id @default(uuid())
  userId    String
  content   String   @db.Text // JSON blob of structured digest
  weekStart DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, weekStart])
}

// ─── Circles (Community Pockets) ─────────────────────────────

model Circle {
  id           String   @id @default(uuid())
  userId       String
  name         String
  color        String   @default("#6B7280")
  icon         String   @default("users")
  followUpDays Int      @default(30)
  sortOrder    Int      @default(0)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts ContactCircle[]

  @@unique([userId, name])
  @@index([userId])
}

model ContactCircle {
  id        String   @id @default(uuid())
  contactId String
  circleId  String
  addedAt   DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  circle  Circle  @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@unique([contactId, circleId])
  @@index([circleId])
  @@index([contactId])
}

// ─── Action Items (extracted from emails) ────────────────────

enum ActionItemStatus {
  OPEN
  DONE
  DISMISSED
}

model ActionItem {
  id             String           @id @default(uuid())
  userId         String
  contactId      String?
  status         ActionItemStatus @default(OPEN)
  title          String
  context        String?          @db.Text  // snippet of the email that triggered it
  sourceId       String?          // Gmail message ID
  threadId       String?          // Gmail thread ID for grouping
  channel        String?          // "gmail", "iMessage", "SMS", "linkedin"
  classification String?          // "action_required", "invitation", "fyi"
  dueDate        DateTime?
  extractedAt    DateTime         @default(now())
  resolvedAt     DateTime?
  resolvedBy     String?          // "auto" | "manual"

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([contactId])
}

// ─── Contact Sightings (Identity Resolution) ─────────────────

model ContactSighting {
  id          String             @id @default(uuid())
  userId      String
  source      ContactSource
  externalId  String?            // source-specific ID for idempotency
  name        String?
  email       String?
  phone       String?
  company     String?
  role        String?
  avatarUrl   String?
  city        String?
  state       String?
  country     String?
  linkedinUrl String?
  rawData     Json?              // full original payload
  seenAt      DateTime           @default(now())
  createdAt   DateTime           @default(now())

  // Resolution outcome
  contactId   String?
  resolution  SightingResolution @default(PENDING)
  confidence  Float?
  resolvedAt  DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([userId, source, externalId])
  @@index([userId, resolution])
  @@index([email])
  @@index([phone])
}

// ─── Journal Entries (private relationship notes) ────────────

enum JournalMood {
  POSITIVE
  NEUTRAL
  CONCERN
}

model JournalEntry {
  id        String      @id @default(uuid())
  contactId String
  userId    String
  content   String      @db.Text
  mood      JournalMood @default(NEUTRAL)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([userId])
}

// ─── Contact Changelog (job/role changes) ────────────────────

enum ChangelogType {
  JOB_CHANGE
  ROLE_CHANGE
  COMPANY_CHANGE
}

enum ChangelogStatus {
  PENDING
  SEEN
  ACTED
  DISMISSED
}

model ContactChangelog {
  id          String          @id @default(uuid())
  contactId   String
  userId      String
  type        ChangelogType
  field       String          // "company", "role"
  oldValue    String?
  newValue    String?
  source      String          @default("linkedin_reimport")
  status      ChangelogStatus @default(PENDING)
  detectedAt  DateTime        @default(now())
  actedAt     DateTime?

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([contactId])
}

// ─── Email Inbox (all synced emails, matched or not) ────────

model EmailMessage {
  id            String    @id @default(uuid())
  userId        String
  gmailId       String    // Gmail message ID for dedup
  threadId      String?   // Gmail thread ID
  fromEmail     String
  fromName      String?
  toEmail       String
  subject       String?
  snippet       String?   @db.Text
  direction     InteractionDirection
  occurredAt    DateTime
  contactId     String?   // null if sender not in contacts
  contactName   String?   // resolved name if matched
  isRead        Boolean   @default(false)
  isAutomated   Boolean   @default(false) // true if List-Unsubscribe or Precedence: bulk/list detected
  createdAt     DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([userId, gmailId])
  @@index([userId, occurredAt])
  @@index([contactId])
}

// ─── Drafts (persistent AI-generated messages) ──────────────

enum DraftStatus {
  DRAFT
  SENT
  DISCARDED
}

enum DraftType {
  REPLY_EMAIL
  CATCHING_UP
  CONGRATULATE
  ASK
  FOLLOW_UP
}

model Draft {
  id          String      @id @default(uuid())
  userId      String
  contactId   String
  status      DraftStatus @default(DRAFT)
  type        DraftType
  tone        String      // casual, warm, professional, congratulatory, checking_in
  content     String      @db.Text
  subjectLine String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  sentAt      DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([contactId])
}

// ─── Gmail Sync State ────────────────────────────────────────

model GmailSyncState {
  id                   String    @id @default(uuid())
  userId               String    @unique
  historyId            String?
  lastSyncAt           DateTime?
  syncEnabled          Boolean   @default(false)
  contactsImported     Boolean   @default(false)
  additionalUserEmails String[]  @default([]) // Other email addresses belonging to this user (for direction detection)
  unmatchedSenders     Json?     // Array of { email: string, count: number } — senders with no matching contact
  mutedThreads         String[]  @default([]) // Gmail threadIds that the user has muted (auto-dismiss future inbound)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── WhatsApp Sync State ─────────────────────────────────────

model WhatsAppSyncState {
  id              String    @id @default(uuid())
  userId          String    @unique
  phone           String
  connected       Boolean   @default(false)
  lastMessageAt   DateTime?
  messagesSynced  Int       @default(0)
  contactsMatched Int       @default(0)
  unmatchedChats  Json?     // Array of { phone, displayName, messageCount }
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── iMessage Sync State (Mac chat.db → individual messages) ─────────

model IMessageSyncState {
  id              String    @id @default(uuid())
  userId          String
  handleId        String    // phone number or email
  contactId       String?   // matched CRM contact ID (for reverse lookup)
  service         String    // "iMessage" or "SMS"
  lastMessageGuid String?   // GUID of the most recent synced message
  lastSyncAt      DateTime?
  messageCount    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, handleId])
  @@index([userId])
  @@index([userId, contactId])
}


// ─── Extension Auth Tokens (Chrome extension bearer auth) ────

model ExtensionToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  label      String    @default("Extension")
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Inbox Items (persistent needs-response tracker) ─────────

enum InboxItemStatus {
  OPEN
  RESOLVED
  DISMISSED
  SNOOZED
}

model InboxItem {
  id          String          @id @default(uuid())
  userId      String
  contactId   String
  channel     String          // normalized: "text", "email", "linkedin"
  threadKey   String          @default("") // group chat ID or email thread ID

  status      InboxItemStatus @default(OPEN)
  resolvedAt  DateTime?
  resolvedBy  String?         // "auto_sync" | "manual" | "dismissed" | "snoozed"
  snoozeUntil DateTime?

  // Denormalized contact info (avoids JOINs on every render)
  contactName      String
  company          String?
  tier             String
  isGroupChat      Boolean     @default(false)
  contactEmail     String?
  contactPhone     String?
  contactLinkedinUrl String?

  // The inbound trigger
  triggerInteractionId String
  triggerAt            DateTime

  // Cached message previews (JSON array, updated on each new inbound)
  messagePreview  Json?      // [{summary, occurredAt, channel}]
  messageCount    Int         @default(1)

  // Cached priority (recomputed on create/update)
  priority        String?    // "high", "medium", "low"
  priorityScore   Int?       // 0-100

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([userId, contactId, channel, threadKey])
  @@index([userId, status])
  @@index([userId, status, triggerAt])
  @@index([contactId])
}
