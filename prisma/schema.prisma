generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ────────────────────────────────────────

model User {
  id                    String    @id @default(uuid())
  name                  String?
  email                 String?   @unique
  emailVerified         DateTime?
  image                 String?
  onboardingCompletedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  contacts             Contact[]
  interactions         Interaction[]
  relationshipInsights RelationshipInsight[]
  weeklyDigests        WeeklyDigest[]
  circles              Circle[]
  actionItems          ActionItem[]
  sightings            ContactSighting[]
  gmailSync            GmailSyncState?
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core CRM Models ────────────────────────────────────────

enum ContactTier {
  INNER_CIRCLE
  PROFESSIONAL
  ACQUAINTANCE
}

enum ContactSource {
  MANUAL
  CSV_IMPORT
  GOOGLE_CONTACTS
  GMAIL_DISCOVER
  APPLE_CONTACTS
  IMESSAGE
  LINKEDIN
  WHATSAPP
}

enum SightingResolution {
  PENDING
  AUTO_MERGED
  REVIEW_NEEDED
  MANUALLY_MERGED
  MANUALLY_REJECTED
  NEW_CONTACT
}

model Contact {
  id              String      @id @default(uuid())
  userId          String
  name            String
  email           String?
  phone           String?
  company         String?
  role            String?
  tier            ContactTier @default(PROFESSIONAL)
  tags            String[]
  linkedinUrl     String?
  city            String?
  state           String?
  country         String?
  latitude        Float?
  longitude       Float?
  notes           String?     @db.Text
  followUpDays    Int?
  lastInteraction DateTime?
  avatarUrl       String?
  source          ContactSource @default(MANUAL)
  importedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  interactions       Interaction[]
  relationshipInsight RelationshipInsight?
  circles            ContactCircle[]
  actionItems        ActionItem[]
  sightings          ContactSighting[]

  @@index([userId])
  @@index([email])
}

enum InteractionType {
  EMAIL
  MESSAGE
  MEETING
  CALL
  NOTE
}

enum InteractionDirection {
  INBOUND
  OUTBOUND
}

model Interaction {
  id         String               @id @default(uuid())
  contactId  String
  userId     String
  type       InteractionType
  direction  InteractionDirection
  channel    String?
  subject    String?
  summary    String?              @db.Text
  occurredAt DateTime
  sourceId   String?
  createdAt  DateTime             @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([occurredAt])
}

// ─── AI Insights Models ────────────────────────────────────

model RelationshipInsight {
  id          String   @id @default(uuid())
  contactId   String   @unique
  userId      String
  healthScore Int      // 0-100
  healthLabel String   // thriving | stable | fading | dormant
  summary     String   @db.Text
  actions     String[] // recommended actions
  computedAt  DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WeeklyDigest {
  id        String   @id @default(uuid())
  userId    String
  content   String   @db.Text // JSON blob of structured digest
  weekStart DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, weekStart])
}

// ─── Circles (Community Pockets) ─────────────────────────────

model Circle {
  id           String   @id @default(uuid())
  userId       String
  name         String
  color        String   @default("#6B7280")
  icon         String   @default("users")
  followUpDays Int      @default(30)
  sortOrder    Int      @default(0)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts ContactCircle[]

  @@unique([userId, name])
  @@index([userId])
}

model ContactCircle {
  id        String   @id @default(uuid())
  contactId String
  circleId  String
  addedAt   DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  circle  Circle  @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@unique([contactId, circleId])
  @@index([circleId])
  @@index([contactId])
}

// ─── Action Items (extracted from emails) ────────────────────

enum ActionItemStatus {
  OPEN
  DONE
  DISMISSED
}

model ActionItem {
  id          String           @id @default(uuid())
  userId      String
  contactId   String?
  status      ActionItemStatus @default(OPEN)
  title       String
  context     String?          @db.Text  // snippet of the email that triggered it
  sourceId    String?          // Gmail message ID
  threadId    String?          // Gmail thread ID for grouping
  dueDate     DateTime?
  extractedAt DateTime         @default(now())
  resolvedAt  DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([contactId])
}

// ─── Contact Sightings (Identity Resolution) ─────────────────

model ContactSighting {
  id          String             @id @default(uuid())
  userId      String
  source      ContactSource
  externalId  String?            // source-specific ID for idempotency
  name        String?
  email       String?
  phone       String?
  company     String?
  role        String?
  avatarUrl   String?
  city        String?
  state       String?
  country     String?
  linkedinUrl String?
  rawData     Json?              // full original payload
  seenAt      DateTime           @default(now())
  createdAt   DateTime           @default(now())

  // Resolution outcome
  contactId   String?
  resolution  SightingResolution @default(PENDING)
  confidence  Float?
  resolvedAt  DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([userId, source, externalId])
  @@index([userId, resolution])
  @@index([email])
  @@index([phone])
}

// ─── Gmail Sync State ────────────────────────────────────────

model GmailSyncState {
  id               String    @id @default(uuid())
  userId           String    @unique
  historyId        String?
  lastSyncAt       DateTime?
  syncEnabled      Boolean   @default(false)
  contactsImported Boolean   @default(false)
  unmatchedSenders Json?     // Array of { email: string, count: number } — senders with no matching contact
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
